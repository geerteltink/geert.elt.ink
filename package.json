{
  "name": "geert.elt.ink",
  "version": "5.3.38",
  "description": "A web developer's playground.",
  "author": "Geert Eltink",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "npm run build & npm-run-all check-links lint:*",
    "check-links": "check-html-links dist",
    "lint": "npm-run-all lint:*",
    "lint:astro": "astro check",
    "lint:types": "tsc --noEmit",
    "lint:imports": "organize-imports-cli ./tsconfig.json",
    "lint:ox": "oxlint --config=.oxlintrc.json --ignore-path=.oxlintignore",
    "lint:es": "eslint . --report-unused-disable-directives --fix --cache",
    "lint:md": "markdownlint src/**/*.mdx",
    "lint:css": "stylelint src/styles/**/*.css",
    "lint:prettier": "prettier . --write --cache --list-different"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.1",
    "@astrojs/rss": "^4.0.10",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/vue": "^5.0.1",
    "@vercel/speed-insights": "^1.1.0",
    "astro": "^5.0.3",
    "date-fns": "^4.1.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.16.0",
    "@eslint/json": "^0.8.0",
    "@eslint/markdown": "^6.2.1",
    "@types/eslint__js": "^8.42.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.1",
    "@types/sanitize-html": "^2.13.0",
    "astro-eslint-parser": "^1.1.0",
    "autoprefixer": "^10.4.20",
    "check-html-links": "^0.2.4",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-prettier": "^5.2.1",
    "markdown-it": "^14.1.0",
    "markdownlint": "^0.36.1",
    "markdownlint-cli": "^0.43.0",
    "npm-run-all2": "^7.0.1",
    "organize-imports-cli": "^0.10.0",
    "oxlint": "^0.14.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "sanitize-html": "^2.13.1",
    "stylelint": "^16.11.0",
    "stylelint-config-recess-order": "^5.1.1",
    "stylelint-config-recommended": "^14.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0"
  }
