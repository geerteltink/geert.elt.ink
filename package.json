{
  "name": "geert.elt.ink",
  "version": "5.3.50",
  "description": "A web developer's playground.",
  "author": "Geert Eltink",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "npm run build & npm-run-all lint:*",
    "lint": "npm-run-all lint:*",
    "lint:astro": "astro check",
    "lint:types": "tsc --noEmit",
    "lint:imports": "organize-imports-cli ./tsconfig.json",
    "lint:ox": "oxlint --config=.oxlintrc.json --ignore-path=.oxlintignore",
    "lint:es": "eslint . --report-unused-disable-directives --fix --cache",
    "lint:md": "markdownlint src/**/*.mdx",
    "lint:css": "stylelint src/styles/**/*.css",
    "lint:prettier": "prettier . --write --cache --list-different"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.4.1",
    "@astrojs/vue": "^5.1.0",
    "astro": "^5.10.1",
    "date-fns": "^4.1.0",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.29.0",
    "@eslint/json": "^0.13.0",
    "@eslint/markdown": "^6.6.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.4",
    "@types/sanitize-html": "^2.16.0",
    "astro-eslint-parser": "^1.2.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-prettier": "^5.5.1",
    "markdown-it": "^14.1.0",
    "markdownlint": "^0.38.0",
    "markdownlint-cli": "^0.45.0",
    "npm-run-all2": "^8.0.4",
    "organize-imports-cli": "^0.10.0",
    "oxlint": "^1.3.0",
    "prettier": "^3.6.1",
    "prettier-plugin-astro": "^0.14.1",
    "sanitize-html": "^2.17.0",
    "stylelint": "^16.21.0",
    "stylelint-order": "^7.0.0",
    "stylelint-config-recess-order": "^7.1.0",
    "stylelint-config-recommended": "^16.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  }
}
