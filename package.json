{
  "name": "geert.elt.ink",
  "version": "5.3.13",
  "description": "A web developer's playground.",
  "author": "Geert Eltink",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "npm run build & npm-run-all check-links lint:*",
    "check-links": "check-html-links dist",
    "lint": "npm-run-all lint:*",
    "lint:astro": "astro check",
    "lint:types": "tsc --noEmit",
    "lint:imports": "organize-imports-cli ./tsconfig.json",
    "lint:ox": "oxlint --config=./.oxlintrc.json --ignore-path=.oxlintignore -D correctness -D suspicious -D perf",
    "lint:es": "eslint . --report-unused-disable-directives --fix --cache",
    "lint:md": "markdownlint src/**/*.mdx",
    "lint:css": "stylelint src/styles/**/*.css",
    "lint:prettier": "prettier . --write --cache --list-different"
  },
  "dependencies": {
    "@astrojs/mdx": "^3.1.7",
    "@astrojs/rss": "^4.0.7",
    "@astrojs/sitemap": "^3.2.0",
    "@astrojs/vue": "^4.5.1",
    "@vercel/speed-insights": "^1.0.12",
    "astro": "^4.15.11",
    "date-fns": "^4.1.0",
    "vue": "^3.5.11"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.12.0",
    "@eslint/json": "^0.6.0",
    "@eslint/markdown": "^6.2.0",
    "@types/eslint__js": "^8.42.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.7.4",
    "@types/sanitize-html": "^2.13.0",
    "astro-eslint-parser": "^1.0.3",
    "autoprefixer": "^10.4.20",
    "check-html-links": "^0.2.4",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.2.4",
    "eslint-plugin-prettier": "^5.2.1",
    "markdown-it": "^14.1.0",
    "markdownlint": "^0.36.1",
    "markdownlint-cli": "^0.42.0",
    "npm-run-all2": "^7.0.1",
    "organize-imports-cli": "^0.10.0",
    "oxlint": "^0.9.9",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "sanitize-html": "^2.13.1",
    "stylelint": "^16.9.0",
    "stylelint-config-recess-order": "^5.1.1",
    "stylelint-config-recommended": "^14.0.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0"
  }
}
