{
  "name": "geert.elt.ink",
  "version": "5.3.56",
  "description": "A web developer's playground.",
  "author": "Geert Eltink",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "npm run build & npm-run-all lint:*",
    "lint": "npm-run-all lint:*",
    "lint:astro": "astro check",
    "lint:types": "tsc --noEmit",
    "lint:imports": "organize-imports-cli ./tsconfig.json",
    "lint:ox": "oxlint --config=.oxlintrc.json --ignore-path=.oxlintignore",
    "lint:es": "eslint . --report-unused-disable-directives --fix --cache",
    "lint:md": "markdownlint src/**/*.mdx",
    "lint:css": "stylelint src/styles/**/*.css",
    "lint:prettier": "prettier . --write --cache --list-different"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vue": "^5.1.4",
    "astro": "^5.18.1",
    "date-fns": "^4.1.0",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^7.5.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/sanitize-html": "^2.16.1",
    "astro-eslint-parser": "^1.4.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "markdown-it": "^14.1.1",
    "markdownlint": "^0.40.0",
    "markdownlint-cli": "^0.48.0",
    "npm-run-all2": "^8.0.4",
    "organize-imports-cli": "^0.10.0",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "sanitize-html": "^2.17.2",
    "stylelint": "^17.5.0",
    "stylelint-order": "^7.0.1",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended": "^18.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
