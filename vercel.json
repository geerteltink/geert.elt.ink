{
  "headers": [
    {
      "source": "/.well-known/webfinger",
      "headers": [
        {
          "key": "content-type",
          "value": "application/activity+json"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "immutable, max-age=31536000"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-index.xml"
    },
    {
      "source": "/index.xml",
      "destination": "/sitemap-index.xml"
    },
    {
      "source": "/atom.xml",
      "destination": "/feed.xml"
    },
    {
      "source": "/rss.xml",
      "destination": "/feed.xml"
    },
    {
      "source": "/blog/feed.xml",
      "destination": "/feed.xml"
    },
