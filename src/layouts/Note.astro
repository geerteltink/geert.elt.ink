---
import CoverImage from '~/components/CoverImage.astro';
import RelativeDate from '~/components/RelativeDate.astro';
import Layout from '~/layouts/Layout.astro';

export interface Props {
  title: string;
  description: string;
  started: Date;
  updated?: Date;
  cover?: string;
}

const { title, description, started, updated, cover } = Astro.props;
---

<Layout>
  <article>
    {
      cover && (
        <div class="cover-image">
          <CoverImage src={cover} alt={title} aspectRatio="21:9" />
        </div>
      )
    }
    <header>
      <h1>
        {title}
      </h1>
      <h2 class="text-medium-emphasis">
        {description}
      </h2>
      <div class="mb-3 text-disabled">
        {
          started && (
            <div>
              Planted <RelativeDate date={started} />
            </div>
          )
        }
        {
          updated && (
            <div>
              Last tended <RelativeDate date={updated} />
            </div>
          )
        }
      </div>
    </header>
    <slot />
  </article>
</Layout>

<style>
  .cover-image {
    margin-bottom: 2rem;
  }
</style>
