---
import { ViewTransitions } from 'astro:transitions';
import Footer from '~/components/Footer.astro';
import HeadMeta, { type Props as HeadMetaProps } from '~/components/HeadMeta.astro';
import Header from '~/components/Header.astro';
import SpeedInsights from '@vercel/speed-insights/astro';

export type Props = HeadMetaProps;

const { ...head } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <HeadMeta {...head} />
    <ViewTransitions />
    <slot name="head" />
    <SpeedInsights />
  </head>
  <body class="page">
    <Header />
    <main class="page-main bg-background container">
      <slot />
    </main>
    <Footer />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-F62S13KXF9" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-F62S13KXF9');
    </script>
  </body>
</html>
