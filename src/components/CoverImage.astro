---
import { Image } from 'astro:assets';

const { src, alt } = Astro.props;
const images = import.meta.glob('/src/assets/*');
---

<Image src={images[src]()} alt={alt} widths={[400, 800, 1280, 1920]} sizes="100vw" />

<style>
  img,
  picture :global(img),
  svg {
    border-radius: 0.5rem;
  }
</style>
