---
import { getCollection } from 'astro:content';
import Card from '~/components/Card.astro';
import Layout from '~/layouts/Layout.astro';

const notes = (await getCollection('notes')).sort(
  (a, b) => b.data.started.valueOf() - a.data.started.valueOf()
);
---

<Layout title="Notes by Geert Eltink" description="My notes">
  <header>
    <h1>Notes</h1>
    <h2 class="text-medium-emphasis">
      Loose, unopinionated notes on things I don’t entirely understand yet.<br />
       Notes are evolving over time and hopefully improving.
    </h2>
  </header>

  <div class="card-deck">
    {
      notes.map((note) => (
        <Card
          href={`/notes/${note.slug}`}
          title={note.data.title}
          started={note.data.started}
          type="note"
        />
      ))
    }
  </div>
</Layout>

<style scoped>
  .card-deck {
    display: flex;
    flex-direction: column;
    flex-flow: row wrap;
  }
</style>
