---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { format, formatISO } from 'date-fns';
import CoverImage from '@components/CoverImage.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
  <article>
    <h1>{entry.data.title}</h1>
    <div class="mb-3 text-disabled">
      {
        entry.data.published && (
          <time datetime={formatISO(entry.data.published, { representation: 'date' })}>
            Published: {format(entry.data.published, 'PPP')}
          </time>
        )
      }
      {
        entry.data.modified && (
          <time datetime={formatISO(entry.data.modified, { representation: 'date' })}>
            Modified: {format(entry.data.modified, 'PPP')}
          </time>
        )
      }
    </div>
    <CoverImage src={entry.data.coverImage} alt={entry.data.coverImageAlt} />
    <Content />
  </article>
</Layout>

<style>
  .cover-image {
    margin-bottom: 2rem;
  }
</style>
