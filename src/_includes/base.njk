<!doctype html>
<html lang="{{ meta.lang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title>{{ title or metadata.title }} · {{ meta.author }} — Software engineer and architect</title>
    {% set desc %}{{ summary or content | summary }}{% endset %}
    <meta name="description" content="{{ desc }}">
    <meta name="generator" content="Eleventy">
    <meta name="web_author" content="Geert Eltink, https://geert.elt.ink/">
    <meta name="dcterms.created" content="{{ page.date | isoDate }}">
    <meta name="dcterms.modified" content="{{ page.date | isoDate }}">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:url" content="{{ page.url | url | absoluteUrl(meta.url) }}">
    <meta name="twitter:title" content="{{ title or metadata.title }}">
    <meta name="twitter:description" content="{{ desc }}">
    <meta name="twitter:image:alt" content="{{ meta.site_name }}">
    <meta property="og:url" content="{{ page.url | url | absoluteUrl(meta.url) }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ title or metadata.title }}">
    <meta property="og:image:alt" content="{{ meta.site_name }}">
    <meta property="og:description" content="{{ desc }}">
    <meta property="og:site_name" content="{{ meta.site_name }}">
    <meta property="og:locale" content="{{ meta.lang }}">
    <meta property="article:author" content="{{ meta.author }}">
    <link rel="alternate" type="application/atom+xml" href="/feed.xml">
    <link rel="stylesheet" href="{{ css.stylesCss }}">
    <link href="https://geert.elt.ink/" rel="me">
    <link href="https://github.com/geerteltink" rel="me">
    <link href="https://mastodon.social/@gpe" rel="me">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.webmanifest">
  </head>
  <body class="page">
    {% include 'header.njk' %}

    {{ content | safe }}

    {% include 'footer.njk' %}

    <!-- Current page: {{ page.url | url }} -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-F62S13KXF9"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-F62S13KXF9');
    </script>
  </body>
</html>
